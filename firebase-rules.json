{
  "rules": {
    "blogs": {
      ".read": true,
      ".write": "auth != null",
      "$blogId": {
        "likes": {
          ".write": true
        }
      }
    },
    "projects": {
      ".read": true,
      ".write": "auth != null"
    },
    "contacts": {
      ".read": "auth != null",
      ".write": true
    }
  }
}
